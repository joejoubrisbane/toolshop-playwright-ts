{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@fixtures/*": ["lib/fixtures/*"],
      "@helpers/*": ["lib/helpers/*"],
      "@pages/*": ["lib/pages/*"],
      "@datafactory/*": ["lib/datafactory/*"]
    },
    "strict": true,
    "module": "commonjs",
    "target": "ES2020",
    "lib": ["ES2020"],
    "esModuleInterop": true
  }
}
